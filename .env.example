# ── Provider selection ────────────────────────────────────────────────────────
# Options: groq (free), deepseek (cheap), anthropic (best quality)
ACE_PROVIDER=groq

# ── Groq (free tier — get key at console.groq.com) ───────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# ACE_GROQ_MODEL=qwen/qwen3-32b   # default
# ACE_GROQ_MODEL=qwen/qwen3-32b                # alternative

# ── DeepSeek (~$0.001 per assignment — platform.deepseek.com) ────────────────
# DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# ACE_DEEPSEEK_MODEL=deepseek-chat              # default

# ── Anthropic (best quality, most expensive) ─────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
# ACE_ANTHROPIC_MODEL=claude-sonnet-4-5         # default
